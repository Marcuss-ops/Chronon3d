#!/usr/bin/env bash
# pre-commit — fast local checks run before every git commit.
#
# Per AGENTS.md: doc SHA dedup, test hygiene, test suite registration.
# All local, no network, exit 1 on violation.
# ═══════════════════════════════════════════════════════════════════════════

set -euo pipefail

SCRIPT_DIR="$(git rev-parse --show-toplevel)/tools"

echo "pre-commit: running fast checks..."

bash "${SCRIPT_DIR}/check_doc_sha_dedup.sh" \
    || { echo "pre-commit: GATE_FAIL on check_doc_sha_dedup.sh (exit $?)" >&2; exit 1; }

bash "${SCRIPT_DIR}/check_test_hygiene.sh" \
    || { echo "pre-commit: GATE_FAIL on check_test_hygiene.sh (exit $?)" >&2; exit 1; }

bash "${SCRIPT_DIR}/check_test_suite_registration.sh" \
    || { echo "pre-commit: GATE_FAIL on check_test_suite_registration.sh (exit $?)" >&2; exit 1; }

echo "pre-commit: fast checks PASSED"
exit 0
