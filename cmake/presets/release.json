{
  "version": 6,
  "include": [
    "base.json",
    "experimental.json"
  ],
  "configurePresets": [
    {
      "name": "__release-base",
      "hidden": true,
      "inherits": "base-linux",
      "displayName": "V0.1 release-only base (hidden helper)",
      "description": "Shared hidden base for the V0.1 release-validation surface. Forces Release buildType, disables experimental, telemetry, profiling, benchmarks, diagnostics. VCPKG manifest features = `tests`; defaults (cli, blend2d, text, mesh, exr) are merged automatically by vcpkg.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CHRONON3D_BUILD_EXPERIMENTAL": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_DIAGNOSTICS": "OFF",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "linux-release-validation",
      "inherits": "__release-base",
      "displayName": "Linux Release Validation (V0.1)",
      "description": "V0.1 release-only validation surface: CLI + text + Blend2D + software renderer + camera (via content) + install consumer + test obbligatori. Disables experimental / telemetry / profiling / benchmarks / diagnostics / expressions-v2. BuildType Release.",
      "cacheVariables": {
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_BUILD_INSTALL_CONSUMER_TEST": "ON"
      }
    },
    {
      "name": "linux-experimental-validation",
      "inherits": "__experimental-base",
      "displayName": "Linux Experimental Validation (full + Expressions V2)",
      "description": "Full-fat experimental validation. Enables Expressions V2 (CHRONON3D_BUILD_EXPERIMENTAL=ON), diagnostics, profiling, telemetry, benchmarks. Nightly/manual only — NOT on the V0.1 release path.",
      "cacheVariables": {
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_ENABLE_VIDEO": "ON",
        "CHRONON3D_ENABLE_MESH": "ON",
        "CHRONON3D_ENABLE_EXR": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-release-validation",
      "configurePreset": "linux-release-validation",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests",
        "chronon3d_sdk_impl"
      ],
      "jobs": 16
    },
    {
      "name": "linux-experimental-validation",
      "configurePreset": "linux-experimental-validation",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests",
        "chronon3d_benchmarks",
        "chronon3d_sdk_impl"
      ],
      "jobs": 16
    }
  ],
  "testPresets": [
    {
      "name": "linux-release-validation-test",
      "configurePreset": "linux-release-validation",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-experimental-validation-test",
      "configurePreset": "linux-experimental-validation",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
