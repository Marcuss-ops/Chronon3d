{
  "version": 6,
  "include": ["base.json"],
  "configurePresets": [
    {
      "name": "linux-ci",
      "inherits": "base-linux",
      "displayName": "Linux CI (daily install-consumer gate)",
      "description": "Daily CI: CLI + content + tests + install consumer + checksum-pinned font fixtures.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_UNITY_BUILD": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_INSTALL_CONSUMER_TEST": "ON",
        "CHRONON3D_BOOTSTRAP_TEST_FONTS": "ON"
      }
    },
    {
      "name": "linux-ci-nocontent",
      "hidden": true,
      "inherits": "linux-ci",
      "displayName": "Linux CI no-content (legacy)",
      "cacheVariables": {
        "CHRONON3D_BUILD_CONTENT": "OFF",
        "CHRONON3D_BOOTSTRAP_TEST_FONTS": "OFF"
      }
    },
    {
      "name": "linux-ci-release-build",
      "inherits": "base-linux",
      "displayName": "Linux CI Release Build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_CONTENT": "OFF",
        "CHRONON3D_ENABLE_TEXT": "ON",
        "CHRONON3D_USE_BLEND2D": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "linux-ci-full-validation",
      "inherits": "base-linux",
      "displayName": "Linux CI Full Validation",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "ON",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "ON",
        "CHRONON3D_ENABLE_TEXT": "ON",
        "CHRONON3D_USE_BLEND2D": "ON",
        "CHRONON3D_ENABLE_EXR": "ON",
        "CHRONON3D_ENABLE_VIDEO": "ON",
        "CHRONON3D_ENABLE_MESH": "ON",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "OFF",
        "CHRONON3D_BOOTSTRAP_TEST_FONTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;mesh;exr;telemetry;tests;benchmarks"
      }
    },
    {
      "name": "linux-ci-render-video-contract",
      "inherits": "base-linux",
      "displayName": "RenderJob contract — video enabled",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_CLI_RENDER": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_CONTENT": "OFF",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "ON",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TEXT": "OFF",
        "CHRONON3D_USE_BLEND2D": "OFF",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "OFF",
        "CHRONON3D_UNITY_BUILD": "OFF",
        "VCPKG_MANIFEST_FEATURES": "cli;tests"
      }
    },
    {
      "name": "linux-ci-render-image-contract",
      "inherits": "linux-ci-render-video-contract",
      "displayName": "RenderJob contract — video disabled",
      "cacheVariables": {
        "CHRONON3D_ENABLE_VIDEO": "OFF"
      }
    },
    {
      "name": "linux-ci-cli-core-only",
      "inherits": "base-linux",
      "displayName": "CLI core-only — render excluded",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_CLI_RENDER": "OFF",
        "CHRONON3D_BUILD_TESTS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "OFF",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "ON",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TEXT": "OFF",
        "CHRONON3D_USE_BLEND2D": "OFF",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "OFF",
        "CHRONON3D_UNITY_BUILD": "OFF",
        "VCPKG_MANIFEST_FEATURES": "cli"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-ci",
      "configurePreset": "linux-ci",
      "targets": ["chronon3d_cli", "chronon3d_tests"],
      "jobs": 16
    },
    {
      "name": "linux-ci-nocontent",
      "configurePreset": "linux-ci-nocontent",
      "targets": ["chronon3d_cli", "chronon3d_tests"],
      "jobs": 16
    },
    {
      "name": "linux-ci-release-build",
      "configurePreset": "linux-ci-release-build",
      "targets": ["chronon3d_cli", "chronon3d_tests"],
      "jobs": 16
    },
    {
      "name": "linux-ci-full-validation",
      "configurePreset": "linux-ci-full-validation",
      "targets": ["chronon3d_cli", "chronon3d_tests"],
      "jobs": 16
    },
    {
      "name": "linux-ci-render-video-contract",
      "configurePreset": "linux-ci-render-video-contract",
      "targets": ["chronon3d_render_job_contract_tests"],
      "jobs": 8
    },
    {
      "name": "linux-ci-render-image-contract",
      "configurePreset": "linux-ci-render-image-contract",
      "targets": ["chronon3d_render_job_contract_tests"],
      "jobs": 8
    },
    {
      "name": "linux-ci-cli-core-only",
      "configurePreset": "linux-ci-cli-core-only",
      "targets": ["chronon3d_cli"],
      "jobs": 8
    }
  ],
  "testPresets": [
    {
      "name": "linux-ci-test",
      "configurePreset": "linux-ci",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-ci-nocontent-test",
      "configurePreset": "linux-ci-nocontent",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-ci-release-build-test",
      "configurePreset": "linux-ci-release-build",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-ci-full-validation-test",
      "configurePreset": "linux-ci-full-validation",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-ci-render-video-contract-test",
      "configurePreset": "linux-ci-render-video-contract",
      "output": {"outputOnFailure": true}
    },
    {
      "name": "linux-ci-render-image-contract-test",
      "configurePreset": "linux-ci-render-image-contract",
      "output": {"outputOnFailure": true}
    }
  ]
}
