{
  "version": 6,
  "configurePresets": [
    {
      "name": "linux-dev",
      "inherits": "base-linux",
      "displayName": "Linux Dev (daily inner loop)",
      "description": "Daily developer preset: CLI + content + telemetry + tests, Debug build, unity build enabled. Text + Blend2D + mesh + EXR (defaults from vcpkg.json).",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "OFF",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;telemetry;tests"
      }
    },
    {
      "name": "linux-asan",
      "inherits": "base-linux",
      "displayName": "Linux ASan + UBSan (DEBUG)",
      "description": "AddressSanitizer + UndefinedBehaviorSanitizer debug preset, tests on. Daily buildType=Debug. NOTE: asan-specific -fsanitize flags override base-linux diag-color+pipe flags.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined",
        "VCPKG_MANIFEST_FEATURES": "tests",
        "CHRONON3D_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-dev",
      "configurePreset": "linux-dev",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests_fast",
        "chronon3d_tests_video"
      ],
      "jobs": 16
    },
    {
      "name": "linux-asan",
      "configurePreset": "linux-asan",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    }
  ],
  "testPresets": [
    {
      "name": "linux-dev-test",
      "configurePreset": "linux-dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-asan-test",
      "configurePreset": "linux-asan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
