{
  "version": 6,
  "include": [
    "base.json"
  ],
  "configurePresets": [
    {
      "name": "linux-ci-core-gate",
      "hidden": true,
      "inherits": "base-linux",
      "displayName": "Linux CI Core Gate (1.3.C/D/E migration target; replaces gates.yml Linux Core Dev reference)",
      "description": "Pre-merge core gate preset for .github/workflows/gates.yml Gate 1 (formerly linux-core-dev). Text/Video/Content/Diagnostics OFF; tests ON. BuildType=Debug, unity OFF.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "OFF",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "OFF",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_TEXT": "OFF",
        "CHRONON3D_USE_BLEND2D": "OFF",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "OFF",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON",
        "CMAKE_UNITY_BUILD_BATCH_SIZE": "16",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "linux-ci-lean-gate",
      "hidden": true,
      "inherits": "base-linux",
      "displayName": "Linux CI Lean Gate (1.3.C/D/E migration target; replaces gates.yml Linux Lean Dev reference)",
      "description": "Pre-merge lean gate preset for .github/workflows/gates.yml Gate 2 (formerly linux-lean-dev). CLI + text + blend2d + tests; no benchmarks/diagnostics/video. BuildType=Debug, ninja, ccache, unity ON. vcpkg CMAKE_PREFIX_PATH is consolidated into cmake/Chronon3DVcpkgToolchain.cmake (single source of truth, TICKET-UNIFIED-VCPKG-TOOLCHAIN); preset no longer hardcodes the vcpkg_installed/ substring.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "OFF",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_TEXT": "ON",
        "CHRONON3D_USE_BLEND2D": "ON",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "OFF",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON",
        "CMAKE_UNITY_BUILD_BATCH_SIZE": "16",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;tests"
      }
    },
    {
      "name": "linux-asan",
      "inherits": "base-linux",
      "displayName": "Linux ASan + UBSan (DEBUG, 7-subsystem gate)",
      "description": "AddressSanitizer + UndefinedBehaviorSanitizer debug preset, tests on. Nightly schedule (P2-A). 7-subsystem cert: 0 OOB / 0 UAF / 0 UB across FontEngine, glyph cache, layout cache, asset resolver, text audit snapshots, renderer session, factory registration. CHRONON3D_ENABLE_TEXT + CHRONON3D_USE_BLEND2D + CHRONON3D_BUILD_CLI_DEV + CHRONON3D_BUILD_DIAGNOSTICS are ON so the 7 subsystems build. NOTE: asan-specific -fsanitize flags override base-linux diag-color+pipe flags.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_UNITY_BUILD": "OFF",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_CLI_DEV": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "ON",
        "CHRONON3D_ENABLE_TEXT": "ON",
        "CHRONON3D_USE_BLEND2D": "ON",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;tests"
      }
    },
    {
      "name": "linux-tsan",
      "inherits": "base-linux",
      "displayName": "Linux TSan (DEBUG, 7-subsystem gate, no unity build)",
      "description": "ThreadSanitizer debug preset, tests on. Weekly schedule (P2-A). 7-subsystem cert: 0 data races across FontEngine, glyph cache, layout cache, asset resolver, text audit snapshots, renderer session, factory registration. Unity build OFF to avoid false-positive cross-TU data races. CHRONON3D_ENABLE_TEXT + CHRONON3D_USE_BLEND2D + CHRONON3D_BUILD_CLI_DEV + CHRONON3D_BUILD_DIAGNOSTICS are ON so the 7 subsystems build. TSan-specific -fsanitize=thread flags override base-linux diag-color+pipe flags.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_UNITY_BUILD": "OFF",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=thread",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_CLI_DEV": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "ON",
        "CHRONON3D_ENABLE_TEXT": "ON",
        "CHRONON3D_USE_BLEND2D": "ON",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;tests"
      }
    },
    {
      "name": "linux-dev",
      "inherits": "base-linux",
      "displayName": "Linux Dev (daily inner loop)",
      "description": "Daily developer preset: CLI + content + telemetry + tests, Debug build, unity build enabled. Text + Blend2D + mesh + EXR (defaults from vcpkg.json).",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "OFF",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;telemetry;tests"
      }
    },
    {
      "name": "linux-content-dev",
      "inherits": "base-linux",
      "displayName": "Linux Content Dev (content + video ON)",
      "description": "Content+video development preset: CLI + content + video + tests. Text + Blend2D enabled. BuildType=Debug, unity build ON. Content ON for composition development and rendering. Video ON for pipe export.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "ON",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;tests;video"
      }
    },
    {
      "name": "linux-dashboard-dev",
      "inherits": "base-linux",
      "displayName": "Linux Dashboard Dev (content ON + dashboard tools)",
      "description": "Dashboard development preset: CLI + content + telemetry + diagnostics + tests. Content ON for dashboard preview rendering. Telemetry ON for dashboard metrics.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_CLI": "ON",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "ON",
        "CHRONON3D_ENABLE_EXR": "OFF",
        "CHRONON3D_ENABLE_VIDEO": "OFF",
        "CHRONON3D_ENABLE_MESH": "OFF",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON",
        "VCPKG_MANIFEST_FEATURES": "cli;blend2d;text;telemetry;tests"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-ci-core-gate",
      "configurePreset": "linux-ci-core-gate",
      "targets": ["chronon3d_tests_fast"],
      "jobs": 16
    },
    {
      "name": "linux-ci-lean-gate",
      "configurePreset": "linux-ci-lean-gate",
      "targets": ["chronon3d_cli", "chronon3d_tests_fast"],
      "jobs": 16
    },
    {
      "name": "linux-asan",
      "configurePreset": "linux-asan",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "linux-tsan",
      "configurePreset": "linux-tsan",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "linux-content-dev",
      "configurePreset": "linux-content-dev",
      "targets": ["chronon3d_cli"],
      "jobs": 16
    },
    {
      "name": "linux-dashboard-dev",
      "configurePreset": "linux-dashboard-dev",
      "targets": ["chronon3d_cli"],
      "jobs": 16
    }
  ],
  "testPresets": [
    {
      "name": "linux-ci-core-gate-test",
      "configurePreset": "linux-ci-core-gate",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "linux-ci-lean-gate-test",
      "configurePreset": "linux-ci-lean-gate",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "linux-asan-test",
      "configurePreset": "linux-asan",
      "output": {
        "outputOnFailure": true
      },
      "environment": {
        "ASAN_OPTIONS": "halt_on_error=1:abort_on_error=1:detect_leaks=1:print_summary=1:print_stacktrace=1:fast_unwind_on_fatal=0:check_initialization_order=1:strict_init_order=1:strict_string_checks=1:detect_stack_use_after_return=1:detect_odr_violation=2:malloc_context_size=20",
        "UBSAN_OPTIONS": "halt_on_error=1:abort_on_error=1:print_stacktrace=1:print_summary=1:report_error_type=1"
      }
    },
    {
      "name": "linux-tsan-test",
      "configurePreset": "linux-tsan",
      "output": {
        "outputOnFailure": true
      },
      "environment": {
        "TSAN_OPTIONS": "halt_on_error=1:abort_on_error=1:second_deadlock_stack=1:print_stacktrace=1:history_size=7:symbolize=1"
      }
    }
  ]
}
