{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/chronon/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "ON",
        "VCPKG_INSTALLED_DIR": "C:/vcpkg/installed"
      }
    },
    {
      "name": "base-win-vs",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "win-vs-novideo",
      "inherits": "base-win-vs",
      "binaryDir": "${sourceDir}/build/win-vs-novideo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_ENABLE_VIDEO": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win-vs-novideo",
      "configurePreset": "win-vs-novideo",
      "configuration": "Debug",
      "targets": [
        "chronon3d_tests"
      ],
      "jobs": 16
    }
  ]
}
