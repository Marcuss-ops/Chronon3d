{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/chronon/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "ON",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed"
      }
    },
    {
      "name": "base-linux",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "base-win",
      "hidden": true,
      "inherits": "base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "linux-release",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_UNITY_BUILD": "OFF"
      }
    },
    {
      "name": "linux-ci",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_UNITY_BUILD": "OFF",
        "CHRONON3D_BUILD_TOOLS": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF"
      }
    },
    {
      "name": "linux-debug-render",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_TESTS": "OFF",
        "CHRONON3D_UNITY_BUILD": "OFF"
      }
    },
    {
      "name": "linux-fast",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_TESTS": "OFF",
        "CHRONON3D_BUILD_TOOLS": "OFF",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "OFF",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_SQLITE_TELEMETRY": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "OFF"
      }
    },
    {
      "name": "linux-dev",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_TOOLS": "OFF",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "OFF",
        "CHRONON3D_ENABLE_SQLITE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON"
      }
    },
    {
      "name": "linux-dev-video",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_TOOLS": "OFF",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "ON",
        "CHRONON3D_ENABLE_SQLITE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON"
      }
    },
    {
      "name": "linux-release-full",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CHRONON3D_BUILD_TESTS": "ON",
        "CHRONON3D_BUILD_TOOLS": "OFF",
        "CHRONON3D_BUILD_BENCHMARKS": "ON",
        "CHRONON3D_BUILD_CONTENT": "ON",
        "CHRONON3D_ENABLE_NATIVE_FFMPEG": "ON",
        "CHRONON3D_ENABLE_SQLITE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_UNITY_BUILD": "ON"
      }
    },
    {
      "name": "linux-asan",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "win-release",
      "inherits": "base-win",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win-debug",
      "inherits": "base-win",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CHRONON3D_UNITY_BUILD": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux",
      "configurePreset": "linux-release",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "linux-ci",
      "configurePreset": "linux-ci",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "linux-debug-render",
      "configurePreset": "linux-debug-render",
      "targets": [
        "chronon3d_cli"
      ],
      "jobs": 16
    },
    {
      "name": "linux-fast",
      "configurePreset": "linux-fast",
      "targets": [
        "chronon3d_cli"
      ],
      "jobs": 16
    },
    {
      "name": "linux-dev",
      "configurePreset": "linux-dev",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests_fast",
        "chronon3d_tests_video"
      ],
      "jobs": 16
    },
    {
      "name": "linux-dev-video",
      "configurePreset": "linux-dev-video",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests_fast",
        "chronon3d_tests_video"
      ],
      "jobs": 16
    },
    {
      "name": "linux-release-full",
      "configurePreset": "linux-release-full",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "win",
      "configurePreset": "win-release",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "win-debug",
      "configurePreset": "win-debug",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    }
  ],
  "testPresets": [
    {
      "name": "linux-test",
      "configurePreset": "linux-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-ci-test",
      "configurePreset": "linux-ci",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-dev-test",
      "configurePreset": "linux-dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-dev-video-test",
      "configurePreset": "linux-dev-video",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-release-full-test",
      "configurePreset": "linux-release-full",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "win-test",
      "configurePreset": "win-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
