{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/chronon/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg_bootstrap/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "ON",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed/${presetName}",
        "VCPKG_MANIFEST_FEATURES": ""
      }
    },
    {
      "name": "base-linux",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "CMAKE_CXX_FLAGS": "-fdiagnostics-color=always -pipe",
        "CMAKE_C_FLAGS": "-fdiagnostics-color=always -pipe"
      }
    },

    {
      "name": "__release-base",
      "hidden": true,
      "inherits": "base-linux",
      "displayName": "V0.1 release-only base (hidden helper)",
      "description": "Shared hidden base for the V0.1 release-validation surface. Forces Release buildType, disables experimental, telemetry, profiling, benchmarks, diagnostics. VCPKG manifest features = `tests`; defaults (cli, blend2d, text, mesh, exr) are merged automatically by vcpkg.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CHRONON3D_BUILD_EXPERIMENTAL": "OFF",
        "CHRONON3D_ENABLE_TELEMETRY": "OFF",
        "CHRONON3D_ENABLE_PROFILING": "OFF",
        "CHRONON3D_BUILD_BENCHMARKS": "OFF",
        "CHRONON3D_BUILD_DIAGNOSTICS": "OFF",
        "CHRONON3D_ENABLE_DIAGNOSTICS": "OFF",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "__experimental-base",
      "hidden": true,
      "inherits": "base-linux",
      "displayName": "Experimental validation base (hidden helper)",
      "description": "Shared hidden base for the experimental-validation surface. Enables Diagnostics + Telemetry + Profiling + Benchmarks + Experimental (Expressions V2). Nightly-manual only — NOT on the V0.1 release path.",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CHRONON3D_BUILD_EXPERIMENTAL": "ON",
        "CHRONON3D_ENABLE_DIAGNOSTICS": "ON",
        "CHRONON3D_BUILD_DIAGNOSTICS": "ON",
        "CHRONON3D_ENABLE_TELEMETRY": "ON",
        "CHRONON3D_ENABLE_PROFILING": "ON",
        "CHRONON3D_BUILD_BENCHMARKS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests;profiling;benchmarks;telemetry"
      }
    },

