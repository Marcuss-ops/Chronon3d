{
  "version": 3,
  "configurePresets": [
    {
      "name": "base-win",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/chronon/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "base-linux",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/chronon/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$env{HOME}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "OFF",
        "VCPKG_INSTALLED_DIR": "${sourceDir}/vcpkg_installed",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "win-release",
      "inherits": "base-win",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "win-debug",
      "inherits": "base-win",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "base-linux",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win",
      "configurePreset": "win-release",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests",
        "code_first_smoke",
        "remotion_style_guide"
      ],
      "jobs": 16
    },
    {
      "name": "win-debug",
      "configurePreset": "win-debug",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests",
        "code_first_smoke",
        "remotion_style_guide"
      ],
      "jobs": 16
    },
    {
      "name": "linux",
      "configurePreset": "linux-release",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "targets": [
        "chronon3d_cli",
        "chronon3d_tests"
      ],
      "jobs": 16
    }
  ],
  "testPresets": [
    {
      "name": "win-test",
      "configurePreset": "win-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-test",
      "configurePreset": "linux-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
