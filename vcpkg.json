{
  "name": "chronon3d",
  "version": "0.1.0",
  "builtin-baseline": "cb2981c4e03d421fa03b9bb5044cd1986180e7e4",
  "overrides": [
    {
      "name": "sqlite3",
      "version": "3.52.0"
    }
  ],
  "dependencies": [
    "spdlog",
    "fmt",
    "glm",
    "tbb",
    "stb",
    "xxhash",
    "highway",
    "nlohmann-json",
    "magic-enum"
  ],
  "features": {
    "mesh": {
      "description": "Mesh processing (CHRONON3D_ENABLE_MESH)",
      "dependencies": ["meshoptimizer"]
    },
    "cli": {
      "description": "CLI application (CHRONON3D_BUILD_CLI)",
      "dependencies": ["cli11"]
    },
    "blend2d": {
      "description": "Blend2D software rendering backend (CHRONON3D_USE_BLEND2D)",
      "dependencies": ["blend2d"]
    },
    "text": {
      "description": "Text rendering — FreeType + HarfBuzz + FriBidi + ZLIB (CHRONON3D_ENABLE_TEXT)",
      "dependencies": ["freetype", "harfbuzz", "fribidi", "zlib"]
    },
    "icu-layout": {
      "description": "ICU-backed line-breaking (CHRONON3D_USE_ICU) — ADR-009 feature; opt-in",
      "dependencies": ["icu"]
    },
    "text-3d": {
      "description": "Text 3D extrusion via libtess2 (CHRONON3D_ENABLE_TEXT_3D) — ADR-009 feature; opt-in",
      "dependencies": ["libtess2"]
    },
    "text-msdf": {
      "description": "MSDF atlas, morph and displacement (CHRONON3D_ENABLE_TEXT_MSDF) — ADR-009 feature; opt-in",
      "dependencies": ["msdfgen"]
    },
    "exr": {
      "description": "OpenEXR image format support (CHRONON3D_ENABLE_EXR)",
      "dependencies": ["openexr"]
    },
    "telemetry": {
      "description": "SQLite telemetry persistence (CHRONON3D_ENABLE_TELEMETRY)",
      "dependencies": ["sqlite3"]
    },
    "tests": {
      "description": "Build tests (requires doctest)",
      "dependencies": ["doctest"]
    },
    "benchmarks": {
      "description": "Build benchmarks (requires Google Benchmark)",
      "dependencies": ["benchmark"]
    },
    "profiling": {
      "description": "Tracy profiling (CHRONON3D_ENABLE_PROFILING)",
      "dependencies": ["tracy"]
    }
  },
  "default-features": ["mesh", "cli", "blend2d", "text", "exr"]
}
