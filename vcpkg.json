{
  "name": "chronon3d",
  "version": "0.1.0",
  "builtin-baseline": "cb2981c4e03d421fa03b9bb5044cd1986180e7e4",
  "dependencies": [
    "spdlog",
    "fmt",
    "glm",
    "taskflow",
    "tbb",
    "stb",
    "concurrentqueue",
    "meshoptimizer",
    "xxhash",
    "highway",
    "cli11",
    "tomlplusplus",
    "blend2d",
    "freetype",
    "harfbuzz",
    "nlohmann-json",
    "openexr",
    "libyuv",
    "magic-enum"
  ],
  "features": {
    "tests": {
      "description": "Build tests (requires doctest)",
      "dependencies": ["doctest"]
    },
    "benchmarks": {
      "description": "Build benchmarks (requires Google Benchmark)",
      "dependencies": ["benchmark"]
    },
    "telemetry": {
      "description": "Enable SQLite telemetry store",
      "dependencies": ["sqlite3"]
    },
    "profiling": {
      "description": "Enable Tracy profiling",
      "dependencies": ["tracy"]
    }
  },
  "default-features": []
}
