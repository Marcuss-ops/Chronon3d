// ── Effect Catalog X-Macro ─────────────────────────────────────────────────
//
// This file is NOT a standalone header — it is #included multiple times
// by effect_catalog.hpp, each time with a different definition of the
// CHRONON_EFFECT macro to extract different information (template
// specializations, catalog entries, etc.).
//
// DO NOT add #pragma once or include guards.
//
// Fields:
//   val           — EffectType numeric value (must match effect_type.hpp)
//   enum_name    — EffectType enumerator name
//   params_type  — Concrete parameter struct (in namespace chronon3d)
//   id_str       — String-view constant from effect_ids.hpp (chronon3d::effects::ids::*)
//   display_name — Human-readable name
//   category     — EffectCategory enum value
//   stage        — EffectStage enum value
//   domain       — EffectDomain (Color / Spatial / Generate / Composite)
//   alpha        — AlphaPolicy (Preserve / MayModify / Generate)
//   dirty        — DirtyPolicy (Preserve / Expand / Translate / FullFrame)
//   bounds       — BoundsPolicy (Preserve / Expand / Translate / FullFrame)
//   temporal     — bool: varies per frame?
//   fusible      — bool: can fuse into ColorPipeline?
//
// ── Core effects (existing, values 1-12) ──

CHRONON_EFFECT(
    1, Blur, BlurParams, ids::BlurGaussian,
    "Gaussian Blur",
    EffectCategory::Blur, EffectStage::LayerPostTransform,
    EffectDomain::Spatial, AlphaPolicy::MayModify,
    DirtyPolicy::Expand, BoundsPolicy::Expand,
    false, false
)

