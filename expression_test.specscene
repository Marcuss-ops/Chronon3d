name = "Expression Test"
width = 1280
height = 720
fps_numerator = 30
fps_denominator = 1
duration = 60

[camera]
enabled = true
zoom = "1000 + sin(time * 2) * 500"

[[layer]]
name = "DynamicRect"
opacity = "0.5 + 0.5 * sin(time * 5)"
position = [640, 360, 0]
is_3d = true

[[layer.visuals]]
type = "rect"
size = [200, 200]
color = [255, 100, 100]
